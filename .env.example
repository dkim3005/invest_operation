# ============================================================
# PoolDesk — environment configuration (TEMPLATE)
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" (it is in .gitignore).
# ============================================================

# ── REQUIRED for the AI Exception Assistant (Module 6) ──────
# Without a key the pipeline still runs: Module 6 falls back to
# a deterministic rule-based classifier. Provide a key to enable
# the real LLM-powered classification + resolution drafting.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Model used by the AI Exception Assistant.
# Haiku is recommended (fast + low cost for classification).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Market data source ──────────────────────────────────────
# synthetic = offline, reproducible price generator (DEFAULT, no key, no network)
# live      = fetch real prices via the yfinance library (no key, needs network)
MARKET_DATA_MODE=synthetic

# ── OPTIONAL — only if you switch live pricing to Alpha Vantage ──
# yfinance (the default for MARKET_DATA_MODE=live) needs NO key.
# This placeholder exists only if a developer prefers Alpha Vantage.
# Leave as-is if you are not using it.
ALPHAVANTAGE_API_KEY=REPLACE_ME_OPTIONAL_NOT_REQUIRED

# ── Pipeline configuration ──────────────────────────────────
BASE_CURRENCY=CAD
SIM_START_DATE=2026-04-01
SIM_DAYS=30
RANDOM_SEED=42

# Database + output locations (relative to project root)
DB_PATH=pooldesk.db
DATA_DIR=data
REPORTS_DIR=reports
